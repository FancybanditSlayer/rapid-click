<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>Rapid Click Battle</title>
<style>
  body {
    background: black;
    color: white;
    text-align: center;
    font-family: sans-serif;
  }

  #game {
    margin-top: 50px;
  }

  #enemy {
    width: 250px;
    cursor: pointer;
    transition: transform 0.1s;
  }

  #enemy:active {
    transform: scale(0.95);
  }

  #hp-bar {
    width: 300px;
    height: 20px;
    background: gray;
    margin: 20px auto;
  }

  #hp {
    height: 100%;
    width: 100%;
    background: red;
  }

  .flash {
    animation: flash 0.1s alternate 6;
  }

  @keyframes flash {
    from { opacity: 1; }
    to { opacity: 0.3; }
  }
</style>
</head>

<body>

<h2>Defeat the Demon King</h2>

<div id="game">
  <img id="enemy" src="demon.png">
  
  <div id="hp-bar">
    <div id="hp"></div>
  </div>

  <p id="text">Click to attack!</p>
</div>

<script>
let hp = 100;
const enemy = document.getElementById("enemy");
const hpBar = document.getElementById("hp");
const text = document.getElementById("text");

enemy.onclick = function() {
  if (hp <= 0) return;

  hp -= 2;
  hpBar.style.width = hp + "%";

  if (hp <= 0) {
    text.innerText = "You defeated the Demon King...";

    enemy.classList.add("flash");

    setTimeout(() => {
      enemy.src = "evil.png"; 
      text.innerText = "Wait... this is you.";
    }, 600);
  }
};
</script>

</body>
</html>
